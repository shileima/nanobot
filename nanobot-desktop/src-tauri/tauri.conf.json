{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nanobot",
  "version": "0.1.0",
  "identifier": "com.shilei.nanobot-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "nanobot",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "frame-src http://localhost:17798 http://127.0.0.1:17798;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
