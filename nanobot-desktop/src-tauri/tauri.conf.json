{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nanobot",
  "version": "1.1.1",
  "identifier": "com.shilei.nanobot-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "nanobot",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "frame-src http://localhost:17798 http://127.0.0.1:17798;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwMTk2NDQyQUEyOENBQjMKUldTenlpaXFRbVFaNE5ZQllZcmJXdTUzd1ZCY3dWSGs5NEtNUnZ1ZnM1Q3JPNVJLN1hIVkdoZEIK",
      "endpoints": [
        "https://github.com/shileima/nanobot/releases/latest/download/latest.json"
      ]
    }
  }
}
